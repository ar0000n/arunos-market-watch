# .env.example — copy this to .env and fill in your values.
# .env is gitignored and never committed.

# Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Gmail account to fetch newsletters from (must be the account you subscribed with)
GMAIL_USER=you@gmail.com

# Gmail App Password — NOT your regular Gmail password.
# Create one at: myaccount.google.com/apppasswords
# Select "Mail" and your device, then paste the 16-char password here.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address to send digests to (can be the same as GMAIL_USER)
NOTIFY_EMAIL=you@gmail.com
